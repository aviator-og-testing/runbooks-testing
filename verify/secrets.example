# Account secrets to add in Aviator (Runbooks > Settings > Secrets) so the verify
# collector can log in. The names must match the secret placeholders used in
# .aviator/verify/skills/; the values map to the accounts this app seeds on startup.
admin_username=admin
admin_password=admin
alice_username=alice
alice_password=password
bob_username=bob
bob_password=password
carol_username=carol
carol_password=password
